{
  "name": "crm-import-rescue",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-only CRM contact import cleanup demo for a productized data service.",
  "scripts": {
    "check": "npm run lint && npm run format:check && npm test",
    "format": "prettier --write \"**/*.{js,mjs,json,html,css,md,yml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,json,html,css,md,yml}\"",
    "lint": "eslint src scripts tests --max-warnings=0",
    "record": "node scripts/record-demo.mjs",
    "test": "node tests/dataRescue.test.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  }
}
